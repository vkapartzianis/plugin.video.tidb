<?xml version="1.0" encoding="UTF-8"?>
<!-- Skip/Watch choice shown while the OSD is up mid-segment. Skip pill is pinned at
     the single-button position (1544,872); Watch sits to its LEFT (1248,872).
     ALL pill textures are set from Python onInit by absolute path, so the visible
     background comes from these image controls (not the button texture).
     Default bg 70% white + dark text; focus = solid white bg + glow ring + 104% zoom. -->
<window type="dialog" id="14001">
    <defaultcontrol always="true">3001</defaultcontrol>
    <coordinates>
        <system>1</system>
        <posx>0</posx>
        <posy>0</posy>
    </coordinates>
    <controls>
        <control type="group">
            <posx>0</posx>
            <posy>0</posy>

            <animation effect="slide" start="40,0" end="0,0" time="260" tween="cubic" easing="out">WindowOpen</animation>
            <animation effect="fade" start="0" end="100" time="260">WindowOpen</animation>
            <animation effect="slide" start="0,0" end="40,0" time="200" tween="cubic" easing="in">WindowClose</animation>
            <animation effect="fade" start="100" end="0" time="200">WindowClose</animation>

            <!-- Watch pill (left) -->
            <control type="group">
                <posx>1248</posx>
                <posy>872</posy>
                <width>280</width>
                <height>56</height>
                <animation effect="zoom" center="auto" start="100" end="104" time="120" tween="sine" easing="out" condition="Control.HasFocus(3002)">Conditional</animation>

                <control type="image" id="3023">
                    <posx>1</posx>
                    <posy>4</posy>
                    <width>280</width>
                    <height>56</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="66000000" border="14">rounded_rect.png</texture>
                </control>
                <control type="image" id="3025">
                    <posx>-5</posx>
                    <posy>-5</posy>
                    <width>290</width>
                    <height>66</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="CCFFFFFF" border="20">rounded_rect.png</texture>
                    <visible>Control.HasFocus(3002)</visible>
                </control>
                <control type="image" id="3024">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>56</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="B3FFFFFF" border="14">rounded_rect.png</texture>
                </control>
                <control type="image" id="3026">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>56</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="FFFFFFFF" border="14">rounded_rect.png</texture>
                    <visible>Control.HasFocus(3002)</visible>
                </control>
                <control type="button" id="3002">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>56</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font24</font>
                    <textcolor>FF111111</textcolor>
                    <focusedcolor>FF111111</focusedcolor>
                    <texturefocus colordiffuse="FFFFFFFF" border="14">rounded_rect.png</texturefocus>
                    <texturenofocus colordiffuse="B3FFFFFF" border="14">rounded_rect.png</texturenofocus>
                    <onright>3001</onright>
                    <label>Watch intro</label>
                </control>
            </control>

            <!-- Skip pill (right, pinned to single-button position) -->
            <control type="group">
                <posx>1544</posx>
                <posy>872</posy>
                <width>280</width>
                <height>56</height>
                <animation effect="zoom" center="auto" start="100" end="104" time="120" tween="sine" easing="out" condition="Control.HasFocus(3001)">Conditional</animation>

                <control type="image" id="3013">
                    <posx>1</posx>
                    <posy>4</posy>
                    <width>280</width>
                    <height>56</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="66000000" border="14">rounded_rect.png</texture>
                </control>
                <control type="image" id="3015">
                    <posx>-5</posx>
                    <posy>-5</posy>
                    <width>290</width>
                    <height>66</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="CCFFFFFF" border="20">rounded_rect.png</texture>
                    <visible>Control.HasFocus(3001)</visible>
                </control>
                <control type="image" id="3014">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>56</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="B3FFFFFF" border="14">rounded_rect.png</texture>
                </control>
                <control type="image" id="3016">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>56</height>
                    <aspectratio>stretch</aspectratio>
                    <texture colordiffuse="FFFFFFFF" border="14">rounded_rect.png</texture>
                    <visible>Control.HasFocus(3001)</visible>
                </control>
                <control type="button" id="3001">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>56</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font24</font>
                    <textcolor>FF111111</textcolor>
                    <focusedcolor>FF111111</focusedcolor>
                    <texturefocus colordiffuse="FFFFFFFF" border="14">rounded_rect.png</texturefocus>
                    <texturenofocus colordiffuse="B3FFFFFF" border="14">rounded_rect.png</texturenofocus>
                    <onleft>3002</onleft>
                    <label>Skip intro</label>
                </control>
            </control>
        </control>
    </controls>
</window>
